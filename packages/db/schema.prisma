// packages/db/schema.prisma
// Handyman Gold Hands CRM — Full schema MVP
// Multi-tenant: every tenant-scoped table has orgId + RLS policy
// LOCAL DEV: uses SQLite (provider controlled by DATABASE_PROVIDER env)
//   DATABASE_URL=file:./dev.db  → SQLite
//   DATABASE_URL=postgresql://...  → Postgres (production)

generator client {
  provider = "prisma-client-js"
}

// Prisma requires the provider to be hardcoded (can't use env()).
// For local dev with SQLite, use the parallel schema.sqlite.prisma file.
// This main schema targets Postgres (Vercel / Supabase / Neon) for production.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS  (SQLite doesn't support native enums — use String below)
// ============================================================

// ============================================================
// CORE MODELS
// ============================================================

model Organization {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  plan       String   @default("starter")
  brandColor String?
  logoUrl    String?
  phone      String?
  email      String?
  address    String?  @db.Text // JSON stored as text
  timezone   String   @default("America/New_York")
  settings   String   @default("{}") @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users         User[]
  customers     Customer[]
  properties    Property[]
  jobs          Job[]
  leads         Lead[]
  technicians   Technician[]
  invoices      Invoice[]
  payments      Payment[]
  calls         Call[]
  attachments   Attachment[]
  auditLogs     AuditLog[]
  estimates     Estimate[]
  jobItems      JobItem[]
  opportunities Opportunity[]
  opportunityItems OpportunityItem[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  orgId          String
  supabaseUserId String?   @unique
  email          String
  phone          String?
  role           String    @default("tech") // admin | dispatcher | tech | customer
  fullName       String
  avatarUrl      String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  lastLogin      DateTime?

  org                    Organization  @relation(fields: [orgId], references: [id])
  technician             Technician?
  dispatched             Job[]         @relation("dispatcher")
  dispatchedOpportunities Opportunity[] @relation("opportunityDispatcher")

  @@unique([orgId, email])
  @@index([orgId])
  @@index([orgId, role])
  @@map("users")
}

model Customer {
  id             String   @id @default(uuid())
  orgId          String
  type           String   @default("residential") // residential | commercial
  companyName    String?
  billingName    String
  email          String?
  phone          String
  alternatePhone String?
  billingAddress String   @db.Text // JSON
  tags           String   @default("[]") @db.Text // JSON array stored as text
  source         String?
  lifetimeValue  Float    @default(0)
  firstServiceAt DateTime?
  lastServiceAt  DateTime?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org           Organization  @relation(fields: [orgId], references: [id])
  properties    Property[]
  jobs          Job[]
  invoices      Invoice[]
  calls         Call[]
  leads         Lead[]
  estimates     Estimate[]
  opportunities Opportunity[]

  @@index([orgId, phone])
  @@index([orgId, email])
  @@index([orgId, createdAt])
  @@map("customers")
}

model Property {
  id           String   @id @default(uuid())
  orgId        String
  customerId   String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  zip          String
  geoLat       Float?
  geoLng       Float?
  accessNotes  String?
  gateCode     String?
  petInfo      String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  org           Organization  @relation(fields: [orgId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  jobs          Job[]
  opportunities Opportunity[]

  @@index([orgId, customerId])
  @@index([orgId, zip])
  @@map("properties")
}

model Technician {
  id             String   @id @default(uuid())
  orgId          String
  userId         String   @unique
  hireDate       DateTime
  hourlyCost     Float
  skills         String   @db.Text // JSON
  certifications String   @default("[]") @db.Text // JSON
  territory      String?  @db.Text // JSON
  rating         Float?
  totalJobs      Int      @default(0)
  isActive       Boolean  @default(true)
  employmentType String   // w2 | contractor_1099

  user          User          @relation(fields: [userId], references: [id])
  org           Organization  @relation(fields: [orgId], references: [id])
  jobs          Job[]
  opportunities Opportunity[]

  @@index([orgId, isActive])
  @@index([orgId, rating])
  @@map("technicians")
}

model Lead {
  id                   String   @id @default(uuid())
  orgId                String
  source               String
  sourceMeta           String   @default("{}") @db.Text // JSON
  customerId           String?
  serviceType          String
  description          String   @db.Text
  zip                  String
  status               String   @default("new") // new|contacted|qualified|converted|dead
  assignedDispatcherId String?
  score                Int      @default(0)
  responseTimeSeconds  Int?
  convertedAt          DateTime?
  receivedAt           DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id])
  customer Customer?    @relation(fields: [customerId], references: [id])
  jobs     Job[]

  @@index([orgId, status, receivedAt])
  @@index([orgId, source])
  @@map("leads")
}

model Job {
  id                   String   @id @default(uuid())
  orgId                String
  jobNumber            String   @unique
  customerId           String
  propertyId           String
  leadId               String?
  // Source tracking — broader than leadId (covers direct calls, walk-ins, repeat customers)
  sourceId             String?  // Future: FK to lead_sources table; nullable until Phase 2
  // Service area — for territory-based dispatch and reporting
  serviceAreaId        String?  // Future: FK to service_areas; nullable until Phase 4
  jobType              String   // repair|install|maintenance|inspection
  category             String   // plumbing|electrical|carpentry|general
  description          String   @db.Text
  status               String   @default("new")
  priority             String   @default("normal") // low|normal|high|emergency
  assignedTechnicianId String?
  dispatcherId         String?
  scheduledStart       DateTime?
  scheduledEnd         DateTime?
  durationEstimateMinutes Int?  // Set by dispatcher / suggested by AI; separate from scheduled window
  actualStart          DateTime?
  actualEnd            DateTime?
  estimatedRevenue     Float?
  actualRevenue        Float?
  laborCost            Float?   // Sum of job_items where itemType=labor (for profit calc)
  partsCost            Float?   // Sum of job_items where itemType=part (for profit calc)
  customerRating       Int?
  customerReview       String?  @db.Text
  internalNotes        String?  @db.Text
  requiresEstimate     Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  org        Organization @relation(fields: [orgId], references: [id])
  customer   Customer     @relation(fields: [customerId], references: [id])
  property   Property     @relation(fields: [propertyId], references: [id])
  lead       Lead?        @relation(fields: [leadId], references: [id])
  technician Technician?  @relation(fields: [assignedTechnicianId], references: [id])
  dispatcher User?        @relation("dispatcher", fields: [dispatcherId], references: [id])
  items      JobItem[]
  invoices   Invoice[]
  calls      Call[]
  attachments Attachment[]
  estimates  Estimate[]

  @@index([orgId, status])
  @@index([orgId, scheduledStart])
  @@index([orgId, assignedTechnicianId, scheduledStart])
  @@index([orgId, customerId])
  @@map("jobs")
}

model JobItem {
  id            String   @id @default(uuid())
  orgId         String
  jobId         String
  opportunityId String?  // backfill target (T-CORE-OPPORTUNITY); becomes NOT NULL after cutover
  itemType      String   // labor|part|service|discount
  name          String
  qty           Float
  unitPrice     Float
  total         Float
  sortOrder     Int      @default(0)

  org Organization @relation(fields: [orgId], references: [id])
  job Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([opportunityId])
  @@index([orgId])
  @@map("job_items")
}

model Estimate {
  id             String   @id @default(uuid())
  orgId          String
  jobId          String
  opportunityId  String?  // backfill target (T-CORE-OPPORTUNITY)
  customerId     String
  estimateNumber String   @unique
  status         String   @default("draft") // draft|sent|approved|rejected|expired
  subtotal       Float
  tax            Float
  total          Float
  validUntil     DateTime
  approvalToken  String?  @unique
  approvedAt     DateTime?
  rejectedAt     DateTime?
  sentAt         DateTime?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())

  org         Organization @relation(fields: [orgId], references: [id])
  job         Job          @relation(fields: [jobId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  customer    Customer     @relation(fields: [customerId], references: [id])

  @@index([orgId, status])
  @@index([orgId, customerId])
  @@index([opportunityId])
  @@map("estimates")
}

model Invoice {
  id              String   @id @default(uuid())
  orgId           String
  jobId           String
  opportunityId   String?  // backfill target (T-CORE-OPPORTUNITY)
  customerId      String
  invoiceNumber   String   @unique
  status          String   @default("draft") // draft|sent|partial|paid|overdue|voided
  subtotal        Float
  tax             Float
  total           Float
  amountPaid      Float    @default(0)
  dueDate         DateTime
  stripeInvoiceId String?  @unique
  sentAt          DateTime?
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  org         Organization @relation(fields: [orgId], references: [id])
  job         Job          @relation(fields: [jobId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  customer    Customer     @relation(fields: [customerId], references: [id])
  payments    Payment[]

  @@index([orgId, status, dueDate])
  @@index([orgId, customerId])
  @@index([opportunityId])
  @@map("invoices")
}

model Payment {
  id             String   @id @default(uuid())
  orgId          String
  invoiceId      String
  amount         Float
  method         String   // card|ach|cash|check|other
  processor      String
  processorTxnId String?  @unique
  status         String
  receivedAt     DateTime @default(now())

  org     Organization @relation(fields: [orgId], references: [id])
  invoice Invoice      @relation(fields: [invoiceId], references: [id])

  @@index([orgId, invoiceId])
  @@index([orgId, receivedAt])
  @@map("payments")
}

model Call {
  id              String   @id @default(uuid())
  orgId           String
  customerId      String?
  leadId          String?
  jobId           String?
  opportunityId   String?  // backfill target (T-CORE-OPPORTUNITY)
  direction       String   // inbound | outbound
  fromNumber      String
  toNumber        String
  twilioCallSid   String?  @unique
  vapiCallId      String?  @unique
  durationSeconds Int?
  recordingUrl    String?
  transcription   String?  @db.Text
  sentimentScore  Float?
  extractedFacts  String?  @db.Text // JSON
  aiSummary       String?  @db.Text
  startedAt       DateTime
  endedAt         DateTime?

  org         Organization @relation(fields: [orgId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  job         Job?         @relation(fields: [jobId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])

  @@index([orgId, startedAt])
  @@index([orgId, customerId])
  @@index([orgId, direction])
  @@index([opportunityId])
  @@map("calls")
}

model Attachment {
  id         String   @id @default(uuid())
  orgId      String
  entityType String
  entityId   String
  fileName   String
  fileType   String
  fileSize   Int?
  url        String
  uploadedBy String?
  uploadedAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])
  job Job?         @relation(fields: [entityId], references: [id], map: "attachment_job_fk")

  @@index([orgId, entityType, entityId])
  @@map("attachments")
}

// ── T-CORE-OPPORTUNITY (D-03) ────────────────────────────────────────────────
// Single record across full Lead → Job → Invoice → Paid lifecycle.
// Replaces Lead+Job split. See projects/crm/T-CORE-OPPORTUNITY-PLAN.md.
//
// Migration strategy: shadow table — Lead+Job tables stay during cutover.
// Old/new readers gate on env OPPORTUNITY_ENABLED. After verify in prod
// (~24-48h), drop legacy tables in separate migration.
model Opportunity {
  id                      String    @id @default(uuid())
  orgId                   String

  // Stage management (string instead of Postgres enum for SQLite parity)
  stage                   String    @default("new_lead")
                                    // OPP_STAGES: new_lead | ai_responding | qualified |
                                    // estimate_sent | estimate_approved | job_created |
                                    // scheduled | on_the_way | in_progress | done |
                                    // invoiced | paid | lost
  stageHistory            String    @default("[]") @db.Text
                                    // JSON: [{stage, enteredAt, exitedAt, durationMs, by}]
  lostReason              String?   // when stage=lost: lost | declined | no_response | canceled | duplicate
  daysInCurrentStage      Int?      // computed by aging cron

  // Source & attribution
  sourceId                String    // 'thumbtack' | 'comeback' | 'website' | 'google_lsa' | ...
  sourceLeadId            String?   // external lead id (e.g. Thumbtack thread id)
  serviceAreaId           String?   // nullable until ServiceArea entity exists

  // Customer info — captured at intake (before Customer record may exist)
  customerId              String?   // null until QUALIFIED+
  customerName            String
  customerPhone           String?
  customerEmail           String?
  serviceCategory         String
  description             String?   @db.Text
  addressLine             String?
  city                    String?
  state                   String?
  zip                     String?

  // AI Conversation link — populated by T18 when Conversation table lands
  conversationId          String?   @unique

  // Job-stage fields (filled at JOB_CREATED+)
  jobNumber               String?   @unique
  propertyId              String?
  scheduledStart          DateTime?
  scheduledEnd            DateTime?
  durationEstimateMinutes Int?
  technicianId            String?
  dispatcherId            String?
  actualStart             DateTime?
  actualEnd               DateTime?

  // Financial — Float for SQLite compat (Postgres Decimal is correct long-term but blocks parity)
  estimateAmount          Float?
  finalAmount             Float?
  laborCost               Float?
  partsCost               Float?

  // Quality
  customerRating          Int?
  customerReview          String?   @db.Text
  internalNotes           String?   @db.Text
  priority                String    @default("normal")

  // Stage-transition timestamps (NULL until reached)
  qualifiedAt             DateTime?
  jobCreatedAt            DateTime?
  scheduledAt             DateTime?
  doneAt                  DateTime?
  paidAt                  DateTime?
  lostAt                  DateTime?

  // Aging tracking
  enteredCurrentStageAt   DateTime  @default(now())
  lastActivityAt          DateTime  @default(now()) @updatedAt

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Legacy IDs for traceability (SQL JOIN-able to old Lead/Job records)
  legacyLeadId            String?   @unique
  legacyJobId             String?   @unique

  // Relations
  org         Organization @relation(fields: [orgId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  property    Property?    @relation(fields: [propertyId], references: [id])
  technician  Technician?  @relation(fields: [technicianId], references: [id])
  dispatcher  User?        @relation("opportunityDispatcher", fields: [dispatcherId], references: [id])
  items       OpportunityItem[]
  invoices    Invoice[]
  estimates   Estimate[]
  attachments Attachment[]
  calls       Call[]

  @@index([orgId, stage, lastActivityAt])
  @@index([orgId, sourceId, createdAt])
  @@index([orgId, technicianId, scheduledStart])
  @@index([orgId, customerId])
  @@map("opportunities")
}

model OpportunityItem {
  id            String  @id @default(uuid())
  orgId         String
  opportunityId String
  itemType      String  // labor | part | service | discount
  name          String
  qty           Float
  unitPrice     Float
  total         Float
  sortOrder     Int     @default(0)

  org         Organization @relation(fields: [orgId], references: [id])
  opportunity Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([orgId])
  @@map("opportunity_items")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  orgId      String
  userId     String?
  action     String
  entityType String
  entityId   String
  before     String?  @db.Text // JSON
  after      String?  @db.Text // JSON
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId, entityType, entityId])
  @@index([orgId, userId])
  @@map("audit_log")
}
